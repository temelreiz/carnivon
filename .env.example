# Database (Neon Postgres)
DATABASE_URL="postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/carnivon?sslmode=require"

# Subdomain config (local dev)
# Set to "true" locally to route /vault paths to vault app via path-based routing
NEXT_PUBLIC_ROOT_DOMAIN="carnivon.io"

# KYC provider (Sumsub / Onfido placeholder)
KYC_PROVIDER_API_KEY=""
KYC_PROVIDER_SECRET=""

# Email (for access requests)
RESEND_API_KEY=""
ACCESS_REQUEST_FROM="Carnivon <no-reply@carnivon.io>"
ACCESS_REQUEST_TO="investors@carnivon.io"

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Optional in dev; set to canonical URL in production (e.g. https://vault.carnivon.io)
AUTH_URL=""

# Apple Sign-In (Services ID + key from developer.apple.com)
AUTH_APPLE_ID=""              # Services ID, e.g. io.carnivon.app
APPLE_TEAM_ID=""              # 10-char Team ID
APPLE_KEY_ID=""               # 10-char Key ID
# Contents of AuthKey_*.p8 — keep as single line with \n for newlines, OR use a
# real multiline value in .env.local. Begins with "-----BEGIN PRIVATE KEY-----".
APPLE_PRIVATE_KEY=""

# Google OAuth (optional — sign-in button hidden when unset)
# Authorized redirect URI in Google Cloud Console:
#   https://vault.carnivon.io/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Pricing engine (FX cron)
# Required in prod: Vercel Cron sends this as `Authorization: Bearer <secret>`.
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# Admin gate — comma-separated emails allowed to access /admin
ADMIN_EMAILS=""
